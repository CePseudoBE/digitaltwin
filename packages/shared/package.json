{
  "name": "@cepseudo/shared",
  "version": "1.0.0",
  "description": "Shared types, errors, utilities, validation, and environment helpers for Digital Twin packages",
  "license": "MIT",
  "author": "Axel Hoffmann",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "node -r ./bin/set-test-env.cjs --import ts-node-maintained/register/esm --enable-source-maps bin/test.ts",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src tests --fix --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@vinejs/vine": "^4.2.0"
  },
  "peerDependencies": {
    "ultimate-express": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "ultimate-express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@japa/assert": "^4.1.0",
    "@japa/runner": "^4.3.0",
    "ts-node-maintained": "^10.9.5",
    "ultimate-express": "^2.0.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CePseudoBE/digitaltwin.git",
    "directory": "packages/shared"
  },
  "keywords": [
    "digitaltwin",
    "shared",
    "types",
    "validation",
    "errors",
    "utilities"
  ],
  "bugs": {
    "url": "https://github.com/CePseudoBE/digitaltwin/issues"
  },
  "homepage": "https://github.com/CePseudoBE/digitaltwin#readme",
  "publishConfig": {
    "access": "public"
  }
}
