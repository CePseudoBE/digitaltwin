{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "outDir": "./dist",
    "rootDir": ".",
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true
  },
  "include": ["tests", "bin"],
  "exclude": ["node_modules", "dist"]
}
