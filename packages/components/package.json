{
  "name": "@digitaltwin/components",
  "version": "1.0.0",
  "description": "Core component base classes for Digital Twin framework (Collector, Harvester, Handler, CustomTableManager)",
  "license": "MIT",
  "author": "Axel Hoffmann",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "node -r ./bin/set-test-env.cjs --import ts-node-maintained/register/esm --enable-source-maps bin/test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@digitaltwin/shared": "workspace:*",
    "@digitaltwin/database": "workspace:*",
    "@digitaltwin/storage": "workspace:*",
    "@digitaltwin/auth": "workspace:*"
  },
  "devDependencies": {
    "@japa/assert": "^4.1.0",
    "@japa/runner": "^4.3.0",
    "ts-node-maintained": "^10.9.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CePseudoBE/digitaltwin.git",
    "directory": "packages/components"
  },
  "keywords": [
    "digitaltwin",
    "components",
    "collector",
    "harvester",
    "handler"
  ],
  "bugs": {
    "url": "https://github.com/CePseudoBE/digitaltwin/issues"
  },
  "homepage": "https://github.com/CePseudoBE/digitaltwin#readme"
}
