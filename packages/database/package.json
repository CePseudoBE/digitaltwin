{
  "name": "@cepseudo/database",
  "version": "1.0.0",
  "description": "Database abstraction layer for Digital Twin framework (Kysely/Knex, PostgreSQL/SQLite)",
  "license": "MIT",
  "author": "Axel Hoffmann",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "node -r ./bin/set-test-env.cjs --import ts-node-maintained/register/esm --enable-source-maps bin/test.ts",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src tests --fix --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@cepseudo/shared": "workspace:*"
  },
  "peerDependencies": {
    "knex": ">=3.0.0",
    "kysely": ">=0.27.0"
  },
  "peerDependenciesMeta": {
    "knex": {
      "optional": true
    },
    "kysely": {
      "optional": true
    }
  },
  "devDependencies": {
    "@japa/assert": "^4.1.0",
    "@japa/runner": "^4.3.0",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/pg": "^8.18.0",
    "better-sqlite3": "^12.6.0",
    "kysely": "^0.28.11",
    "pg": "^8.20.0",
    "ts-node-maintained": "^10.9.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CePseudoBE/digitaltwin.git",
    "directory": "packages/database"
  },
  "keywords": [
    "digitaltwin",
    "database",
    "knex",
    "kysely",
    "postgresql",
    "sqlite"
  ],
  "bugs": {
    "url": "https://github.com/CePseudoBE/digitaltwin/issues"
  },
  "homepage": "https://github.com/CePseudoBE/digitaltwin#readme"
}
