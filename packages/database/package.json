{
  "name": "@digitaltwin/database",
  "version": "1.0.0",
  "description": "Database abstraction layer for Digital Twin framework (Kysely/Knex, PostgreSQL/SQLite)",
  "license": "MIT",
  "author": "Axel Hoffmann",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "node -r ./bin/set-test-env.cjs --import ts-node-maintained/register/esm --enable-source-maps bin/test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@digitaltwin/shared": "workspace:*"
  },
  "peerDependencies": {
    "knex": ">=3.0.0",
    "kysely": ">=0.27.0"
  },
  "peerDependenciesMeta": {
    "knex": {
      "optional": true
    },
    "kysely": {
      "optional": true
    }
  },
  "devDependencies": {
    "@japa/assert": "^4.1.0",
    "@japa/runner": "^4.3.0",
    "better-sqlite3": "^12.6.0",
    "knex": "^3.1.0",
    "kysely": "^0.28.11",
    "ts-node-maintained": "^10.9.5"
  }
}
