{
  "name": "digitaltwin",
  "private": true,
  "type": "module",
  "description": "Digital Twin Framework Monorepo",
  "scripts": {
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @cepseudo/shared run build",
    "build:core": "pnpm --filter digitaltwin-core run build",
    "build:cli": "pnpm --filter digitaltwin-cli run build",
    "build:create": "pnpm --filter create-digitaltwin run build",
    "clean": "pnpm -r run clean",
    "test": "pnpm --filter @cepseudo/shared run test && pnpm --filter @cepseudo/database run test && pnpm --filter @cepseudo/storage run test && pnpm --filter @cepseudo/auth run test && pnpm --filter @cepseudo/assets run test && pnpm --filter @cepseudo/ngsi-ld run test && pnpm --filter @cepseudo/engine run test && pnpm --filter digitaltwin-core run test",
    "test:e2e": "pnpm --filter @cepseudo/e2e test",
    "test:shared": "pnpm --filter @cepseudo/shared run test",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "pnpm --filter digitaltwin-core run format",
    "format:check": "pnpm --filter digitaltwin-core run format:check",
    "check": "pnpm --filter digitaltwin-core run check"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.1.0",
    "eslint": "^9.39.2",
    "globals": "^15.15.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.53.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "lodash": ">=4.17.23",
      "diff": ">=4.0.4"
    }
  }
}
